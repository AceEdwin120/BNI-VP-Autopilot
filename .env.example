# BNI-VP-Autopilot secrets — copy to ~/.openclaw/secrets/bni-masta.env, then chmod 600
#
# Every value here is a TEMPLATE. Fill them in for your own chapter; never commit
# this file with real values. The runtime expects this file at the path above.

# === LLM brains ===

# OpenRouter — transcription (Gemini 2.5 Flash) + chat brain (Claude Haiku 4.5)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic — wiki compiler brain via the local `claude` CLI.
# Leave empty if `claude` CLI is already logged in via `claude /login`.
ANTHROPIC_API_KEY=

# OpenAI Codex OAuth (legacy chat brain fallback) — handled by `~/.openclaw/auth-profiles/openai-codex.json`
# No env var needed; provision via `openclaw auth add openai-codex` instead.

# === Meeting bot (Vexa, open-source — replaces Recall.ai) ===
# Sign up at https://vexa.ai (or self-host: https://github.com/Vexa-ai/vexa)
# TODO(template): the original BNI-Masta wired Recall.ai. The Vexa API surface
# is similar but NOT identical — search for `TODO(vexa)` in the codebase to find
# the spots you must adjust (POST body shape, webhook event names, transcript
# polling endpoint).
VEXA_API_KEY=
VEXA_REGION=ap-northeast-1
# Public webhook URL → tunneled to http://127.0.0.1:18821. Use Cloudflare Tunnel.
VEXA_WEBHOOK_URL=https://<your-subdomain>.<your-domain>/vexa-webhook
VEXA_WEBHOOK_SECRET=
VEXA_WEBHOOK_PORT=18821

# === Google ===
# Create a dedicated "BNI" calendar, paste its Calendar ID:
BNI_CALENDAR_ID=c_...@group.calendar.google.com
# Roster Sheet — see roster-sync/SKILL.md for required tab layout
BNI_ROSTER_SHEET_ID=<your-google-sheet-id>

# === Telegram (operator alerts + DM control) ===
BNI_BOT_TOKEN=
ALEX_TELEGRAM_ID=

# === LINE Messaging API ===
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
ALEX_LINE_ID=

# === LINE delivery targets (ai-news + post-meeting fan-out) ===
# Bot-leg group IDs (must start with uppercase 'C') — comma-separated
LINE_TARGET_GROUP_IDS=
# CU-leg display names (Computer Use substring-matches against LINE.app sidebar)
BNI_PERSONAL_LINE_TARGETS=
BNI_PERSONAL_LINE_TEST_TARGETS=
BNI_PERSONAL_LINE_MODE=test

# === Bot identity ===
# Display name shown in Zoom + LINE messages. Customize for your chapter.
BNI_BOT_DISPLAY_NAME=BNI Masta(<YourName>副主席習ＡＩ助理)
BNI_BOT_AVATAR_URL=https://<your-webhook-host>/assets/masta-avatar.html

# === Apify (AI News Broadcaster scraping) ===
APIFY_TOKEN=
