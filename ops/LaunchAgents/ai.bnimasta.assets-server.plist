<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.bnimasta.assets-server</string>
    <key>RunAtLoad</key><true/>
    <key>KeepAlive</key><true/>
    <key>ProgramArguments</key>
    <array>
      <string>/opt/homebrew/bin/node</string>
      <string>~/.openclaw/agents/bni-masta/services/assets-server.mjs</string>
    </array>
    <key>StandardOutPath</key><string>~/.openclaw/agents/bni-masta/services/assets-server.stdout.log</string>
    <key>StandardErrorPath</key><string>~/.openclaw/agents/bni-masta/services/assets-server.stderr.log</string>
  </dict>
</plist>
